MONGODB_URI=
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h
PORT=3000

# Optional: comma-separated *exact* Origins the browser will send (scheme + host + port, no path).
# If omitted, all origins are allowed.
# CORS_ORIGINS=https://lms.ziloty.in
#
# API routes are under /api (global prefix). Swagger: https://host/api/docs - proxy /api/ to this app.

