MONGODB_URI=
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h
PORT=3000

# Optional: comma‑separated *exact* Origins the browser will send (scheme + host + port, no path).
# Example if SPA is opened as https://lms.ziloty.in and as http://18.60.216.135:9000, list both.
# If omitted, all origins are allowed. Wrong/missing values cause CORS errors in the browser.
# CORS_ORIGINS=https://lms.ziloty.in,http://18.60.216.135:9000

